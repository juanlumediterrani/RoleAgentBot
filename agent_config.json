{
  "personality": "personalities/kronk.json",
  "platform": "discord",
  "roles": {
    "news_watcher": {
      "enabled": true,
      "interval_hours": 1,
      "script": "roles/news_watcher/news_watcher.py"
    },
    "treasure_hunter": {
      "enabled": true,
      "interval_hours": 1,
      "script": "roles/treasure_hunter/treasure_hunter.py"
    },
    "trickster": {
      "enabled": true,
      "interval_hours": 12,
      "script": "roles/trickster/trickster.py",
      "subroles": {
        "beggar": {
          "enabled": true,
          "frequency_hours": 12
        },
        "dice_game": {
          "enabled": true,
          "fixed_bet": 10
        },
        "ring": {
          "enabled": true,
          "frequency_hours": 24
        }
      }
    },
    "mc": {
      "enabled": true,
      "mode": "integrated",
      "features": {
        "voice_commands": true,
        "queue_management": true,
        "playlist_support": true,
        "auto_disconnect": true,
        "mention_responses": true,
        "presence_status": true
      },
      "voice_settings": {
        "timeout_seconds": 60,
        "auto_disconnect_timeout": 300,
        "max_queue_size": 50,
        "volume": 1.0
      },
      "audio_quality": {
        "bitrate": "128k",
        "format": "mp3",
        "before_options": "-reconnect 1 -reconnect_streamed 1 -reconnect_delay_max 5"
      }
    },
    "banker": {
      "enabled": true,
      "interval_hours": 24,
      "script": "roles/banker/banker.py"
    }
  }
}

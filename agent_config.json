{
  "default_personality": "rab",
  "default_language": "en-US",
  "platform": "discord",
  "llm": {
    "max_tokens": 2048
  },
  "fatigue_limits": {
    "user": {
      "daily_max": 50,
      "hourly_max": 10,
      "burst_max": 5,
      "reset_times": {
        "daily": "00:00 UTC",
        "hourly": "cada hora"
      }
    },
    "server": {
      "daily_max": 500,
      "hourly_max": 100,
      "burst_max": 20
    },
    "exemptions": {
      "admin_users": [],
      "critical_tasks": ["daily_memory", "relationship_memory", "recent_memory"]
    },
    "behavior": {
      "strict_mode": false,
      "grace_period": 3,
      "cooldown_minutes": 15
    }
  },
  "roles": {
    "news_watcher": {
      "enabled": true,
      "interval_hours": 1,
      "script": "roles/news_watcher/news_watcher.py"
    },
    "treasure_hunter": {
      "enabled": true,
      "interval_hours": 1,
      "script": "roles/treasure_hunter/treasure_hunter.py"
    },
    "trickster": {
      "enabled": true,
      "interval_hours": 12,
      "script": "roles/trickster/trickster.py",
      "subroles": {
        "beggar": {
          "enabled": true,
          "frequency_hours": 12
        },
        "dice_game": {
          "enabled": true,
          "fixed_bet": 10
        },
        "ring": {
          "enabled": true,
          "frequency_hours": 24
        },
        "nordic_runes": {
          "enabled": true
        }
      }
    },
    "mc": {
      "enabled": true,
      "mode": "integrated",
      "features": {
        "voice_commands": true,
        "queue_management": true,
        "playlist_support": true,
        "auto_disconnect": true,
        "mention_responses": true,
        "presence_status": true
      },
      "voice_settings": {
        "timeout_seconds": 60,
        "auto_disconnect_timeout": 300,
        "max_queue_size": 50,
        "volume": 1.0
      },
      "audio_quality": {
        "bitrate": "128k",
        "format": "mp3",
        "before_options": "-reconnect 1 -reconnect_streamed 1 -reconnect_delay_max 5"
      }
    },
    "banker": {
      "enabled": true,
      "interval_hours": 24,
      "script": "roles/banker/banker.py"
    }
  }
}

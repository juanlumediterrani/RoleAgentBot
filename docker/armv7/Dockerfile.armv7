# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.armv7 - Imagen optimizada para Raspberry Pi 32 bits (ARMv7)
#
# Build:
#   docker build --platform=linux/arm/v7 -f docker/armv7/Dockerfile.armv7 \
#                --build-arg PERSONALITY=putre \
#                --build-arg ACTIVE_ROLES="news_watcher,treasure_hunter,trickster,banker,mc" \
#                -t roleagentbot:putre-armv7 .
#
# If no arguments are passed, the personality and roles defined in
# agent_config.json are used as-is in the repository.
# ─────────────────────────────────────────────────────────────────────────────
FROM --platform=linux/arm/v7 python:3.11-slim-bullseye

# Install system dependencies optimized for ARM
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    git \
    curl \
    sqlite3 \
    build-essential \
    libffi-dev \
    python3-dev \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Install PyNaCl for Discord voice
RUN pip install --no-cache-dir PyNaCl

# Copy main source code
COPY agent_config.json .
COPY run.py .
COPY agent_*.py .
COPY *.py .

# Copy discord_bot and other modules
COPY discord_bot/ discord_bot/
COPY personalities/ personalities/
COPY roles/ roles/
COPY postprocessor.py .

# ── Script that applies ARG to agent_config.json at startup ──────
COPY docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# ── Directories with persistent state (mounted as volumes) ──────────────
RUN mkdir -p databases logs fatiga

# ── Build arguments ────────────────────────────────────────────────
ARG PERSONALITY=""
ARG ACTIVE_ROLES=""

# Variables de entorno que el entrypoint puede leer
ENV PERSONALITY=${PERSONALITY}
ENV ACTIVE_ROLES=${ACTIVE_ROLES}

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["python", "run.py"]

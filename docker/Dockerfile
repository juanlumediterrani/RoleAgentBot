# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile principal - Imagen completa del bot para VPS
#
# Características:
# - Configuración mínima para VPS sin puertos hacia afuera
# - Incluye todas las dependencias para todos los roles
# - JavaScript runtime (Node.js) para cookies de YouTube
# - Librerías multimedia completas para música y voz
# - Librerías criptográficas para seguridad
#
# Dependencias incluidas:
# - PyNaCl para voz de Discord
# - yt-dlp y ffmpeg para música
# - Node.js para signature solving de YouTube
# - Librerías de desarrollo para compilación
# - Librerías multimedia para procesamiento de audio
# - Librerías criptográficas para seguridad
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.13-slim

WORKDIR /app

# Cambiar a root para instalar paquetes
USER root

# ARG definitions must come before they are used
ARG ENABLE_MC=false
ARG PERSONALITY=""
ARG ACTIVE_ROLES=""

# Instalar dependencias del sistema (configuración mínima para VPS sin puertos hacia afuera)
RUN apt-get update && apt-get install -y --no-install-recommends \
        # Compiladores y desarrollo (siempre necesarios)
        gcc \
        libffi-dev \
        python3-dev \
        make \
        # Librerías de sistema para Python (siempre necesarias)
        libssl-dev \
        libsqlite3-dev \
        # Utilidades del sistema (siempre necesarias)
        curl \
        wget \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Instalar paquetes específicos para MC solo si está habilitado
RUN if [ "$ENABLE_MC" = "true" ]; then \
        apt-get update && apt-get install -y --no-install-recommends \
            # Multimedia y audio (esencial para música)
            ffmpeg \
            # JavaScript runtime (esencial para cookies de YouTube)
            nodejs \
            # Librerías para procesamiento de audio/video
            libavformat-dev \
            libavcodec-dev \
            libavdevice-dev \
            libavfilter-dev \
            libswscale-dev \
            libswresample-dev \
            # Librerías para criptografía de Discord
            libopus-dev \
            libsodium-dev \
        && rm -rf /var/lib/apt/lists/*; \
    fi

# Instalar dependencias Python (como root para evitar permisos)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Instalar dependencias adicionales para voz
RUN pip install PyNaCl

# Volver a usuario normal (usará root para manejar volúmenes)
USER root


# ── Código fuente principal ───────────────────────────────────────────────────
COPY agent_config.json .
COPY agent_db.py .
COPY agent_engine.py .
COPY agent_fatigue_limits.py .
COPY agent_logging.py .
COPY agent_mind.py .
COPY agent_roles_db.py .
COPY agent_runtime.py .
COPY discord_force_watcher_command.py .
COPY init_roles_config.py .
COPY postprocessor.py .
COPY prompts_logger.py .
COPY run.py .
COPY ARCHITECTURE.md .
COPY README_USER.md .

# Create necessary directories
RUN mkdir -p /app/logs /app/databases /app/fatiga /app/cookies

# Create cookies.txt placeholder with instructions
RUN echo "# YouTube Cookies File\n# Place your YouTube cookies here for improved YouTube access\n# Generated by yt-dlp. Do not edit.\n# Instructions:\n# 1. Install 'Get cookies.txt' extension in your browser\n# 2. Log into YouTube in your browser\n# 3. Export cookies in Netscape format\n# 4. Copy content here or mount as volume\n" > /app/cookies.txt

# Copy remaining code
COPY behavior/ behavior/
COPY discord_bot/ discord_bot/
COPY personalities/ personalities/
COPY roles/ roles/
COPY docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Environment variables that the entrypoint can read
ENV PERSONALITY=${PERSONALITY}
ENV ACTIVE_ROLES=${ACTIVE_ROLES}

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["python", "run.py"]

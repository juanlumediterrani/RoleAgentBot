# Discord Bot Configuration
# Copy this file to .env and fill in your actual values

# Discord Bot Token (required)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# LLM Provider Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Vertex AI Configuration (optional)
# Set DISABLE_VERTEX_AI=true to disable Vertex AI (useful for troubleshooting)
# Leave empty or set to false to enable Vertex AI
DISABLE_VERTEX_AI=false

# Google Cloud Authentication (required if Vertex AI is enabled)
# Option 1: Use gcloud auth application-default login (recommended)
# Option 2: Set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Premium SKU Configuration (optional - for monetization)
# Get these from Discord Developer Portal -> Monetization -> Manage SKUs
# Leave empty to disable premium features
DISCORD_FATIGUE_RESET_SKU_ID=1491597605699063828
DISCORD_PREMIUM_GUILD_SKU_ID=

# Additional Configuration
# Add any other environment variables your bot needs

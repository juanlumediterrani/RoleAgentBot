# Discord Bot Configuration
# Copy this file to .env and fill in your actual values

# Discord Bot Token (required)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# LLM Provider Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Premium SKU Configuration (optional - for monetization)
# Get these from Discord Developer Portal -> Monetization -> Manage SKUs
# Leave empty to disable premium features
DISCORD_FATIGUE_RESET_SKU_ID=
DISCORD_PREMIUM_GUILD_SKU_ID=

# Additional Configuration
# Add any other environment variables your bot needs

  "public_context_suffix": "Estas hablando en un canal publico con MUCHOS humanos. Usa PLURAL: 'ustedes', 'umanos', 'todos ustedes'.",
  "context_history_label": "Historial",
  "context_important_label": "CONTEXTO IMPORTANTE - Anillo",
  "history_keywords": ["anillo", "anilo", "ring"],
  "context_labels": {
